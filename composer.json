{
  "name": "systopia/civicrm-test-fixtures",
  "type": "library",
  "description": "Reusable PHPUnit fixtures for CiviCRM extensions",
  "minimum-stability": "stable",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "authors": [
    {
      "name": "SYSTOPIA",
      "email": "info@systopia.de",
      "homepage": "https://www.systopia.de"
    }
  ],
  "autoload": {
    "psr-4": {
      "Systopia\\TestFixtures\\": "src/",
      "Systopia\\TestFixtures\\Tests\\": "tests/phpunit/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Systopia\\TestFixtures\\Tests\\": "tests/phpunit/"
    }
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/civicrm/coder.git"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.13",
    "drupal/coder": "dev-8.x-2.x-civi",
    "friendsofphp/php-cs-fixer": "^3.94",
    "rector/rector": "^2.3"
  },
  "scripts": {
    "phpstan": [
      "@php ./vendor/bin/phpstan -v"
    ],
    "phpcs": [
      "@php ./vendor/bin/phpcs"
    ],
    "phpcbf": [
      "@php ./vendor/bin/phpcbf"
    ],
    "phpunit": [
      "@php ./vendor/bin/phpunit --coverage-text"
    ],
    "phpunit:html": [
      "@php ./vendor/bin/phpunit --coverage-html /var/www/html/coverage"
    ],
    "reset:db": [
      "bash ./bin/reset-test-db.sh"
    ],
    "rector": [
      "@php ./vendor/bin/rector process"
    ],
    "rector:test": [
      "@php ./vendor/bin/rector process --dry-run"
    ],
    "php-cs-fixer": [
      "@php ./vendor/bin/php-cs-fixer fix --config=php-cs-fixer.php"
    ],
    "php-cs-fixer:test": [
      "@php ./vendor/bin/php-cs-fixer fix --dry-run --diff --config=php-cs-fixer.php"
    ],
    "fix": [
      "@rector",
      "@php-cs-fixer",
      "@phpcbf"
    ],
    "test": [
      "@rector:test",
      "@php-cs-fixer:test",
      "@phpcs",
      "@phpstan",
      "@phpunit"
    ]
  },
  "config": {
    "platform": {
      "php": "8.1"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
