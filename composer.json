{
  "name": "systopia/test-fixtures",
  "type": "library",
  "description": "Reusable PHPUnit fixtures for CiviCRM extensions",
  "minimum-stability": "stable",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "authors": [
    {
      "name": "Daniel Hahn",
      "email": "hahn@systopia.de"
    }
  ],
  "autoload": {
    "psr-4": {
      "Systopia\\TestFixtures\\": "src/",
      "Systopia\\TestFixtures\\Tests\\": "tests/phpunit/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Systopia\\TestFixtures\\Tests\\": "tests/phpunit/"
    }
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/civicrm/coder.git"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.13",
    "drupal/coder": "dev-8.x-2.x-civi"
  },
  "scripts": {
    "phpstan": [
      "@php ./vendor/bin/phpstan -v"
    ],
    "phpcs": [
      "@php ./vendor/bin/phpcs"
    ],
    "phpcbf": [
      "@php ./vendor/bin/phpcbf"
    ],
    "phpunit": [
      "@php ./vendor/bin/phpunit --coverage-text"
    ],
    "phpunit:html": [
      "@php ./vendor/bin/phpunit --coverage-html /var/www/html/coverage"
    ],
    "reset:db": [
      "bash ./bin/reset-test-db.sh"
    ]
  },
  "config": {
    "platform": {
      "php": "8.1"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
